<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<VBox xmlns="http://javafx.com/javafx"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.github.asciborek.last_fm.LastFmSettingsWindowController"
  minHeight="150.0" minWidth="250.0">

  <HBox spacing="10.0">
    <Text fx:id="loginStatusText" text="You are not logged in..." />
    <Button fx:id="loginButton" text="Login" onMouseClicked="#onLogin"/>
  </HBox>
</VBox>
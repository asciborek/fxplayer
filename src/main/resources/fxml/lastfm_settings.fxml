<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.github.asciborek.last_fm.LastFmSettingsWindowController"
  minHeight="150.0" minWidth="250.0"
  spacing="15.0"
  style="-fx-padding: 15.0;">

  <Text fx:id="loginStatusText"
    text="You are not logged in..."
    style="-fx-font-size: 12px; -fx-fill: #555555;"/>

  <HBox spacing="10.0" alignment="CENTER_LEFT">
    <StackPane HBox.hgrow="NEVER" minWidth="80.0">
      <Button fx:id="loginButton"
        text="Login"
        onMouseClicked="#onLogin"
        style="-fx-font-size: 11px; -fx-padding: 8px 16px;"
        minWidth="80.0"/>
      <Button fx:id="logoutButton"
        text="Logout"
        onMouseClicked="#onLogout"
        style="-fx-font-size: 11px; -fx-padding: 8px 16px;"
        minWidth="80.0"/>
    </StackPane>

    <ProgressIndicator fx:id="loadingIndicator"
      visible="false"
      managed="false"
      minWidth="30.0"
      minHeight="30.0"
      maxWidth="30.0"
      maxHeight="30.0"
      style="-fx-padding: 0;"/>
  </HBox>
</VBox>
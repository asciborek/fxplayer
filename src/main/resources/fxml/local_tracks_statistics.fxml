<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns="http://javafx.com/javafx"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.github.asciborek.local_statistics.LocalTrackStatisticsController"
  minHeight="100.0" minWidth="300.0">

  <HBox>
    <Label text="Total Plays Count" minWidth="120" />
    <TextField fx:id="totalPlaysCount" minWidth="180" editable="false"/>
  </HBox>
  <HBox>
    <Label text="First Played" minWidth="120"/>
    <TextField fx:id="firstPlayed" minWidth="180" editable="false"/>
  </HBox>
  <HBox>
    <Label text="Last Played" minWidth="120"/>
    <TextField fx:id="lastPlayed" minWidth="180" editable="false"/>
  </HBox>
</VBox>